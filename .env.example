# Copy this file to .env and fill in the values. NEVER commit .env.
# Generate a fresh key at https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-7

# Local dev
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# MCPs (optional overrides — leave blank to use bundled vendor/ clients)
SKETCHUP_MCP_HOST=127.0.0.1
SKETCHUP_MCP_PORT=9876
AUTOCAD_MCP_HOST=127.0.0.1
AUTOCAD_MCP_PORT=9877
# When AutoCAD is running with mcp_dispatch.lsp loaded, point this at the
# watch folder the LISP monitors (usually `<repo>/autocad_watch`).
# AUTOCAD_MCP_WATCH_DIR=C:\Users\redaz\Desktop\Design Office\autocad_watch

# Token budget guardrails (section 16)
NIGHTLY_INPUT_TOKENS_BUDGET=300000
NIGHTLY_OUTPUT_TOKENS_BUDGET=100000

# fal.ai (NanoBanana Pro). Generate a key at https://fal.ai/dashboard/keys
# Powers the editorial product photography on the Mood Board surface —
# atmosphere, biophilic, materials and furniture gallery tiles plus
# per-item product photographs (one per material / furniture / plant /
# light fixture in the curator selection).
FAL_KEY=REPLACE_ME

# Disk cache for generated images. Re-running the same (model, prompt,
# aspect_ratio) is served from this folder so the cost is paid once.
# Each PNG ships with a `{cache_key}.json` sidecar tagging its content
# category (material / furniture / plant / light / atmosphere /
# biophilic / hero_composite), which keeps the moodboard's per-slot
# lookup robust to prompt variations.
NANOBANANA_CACHE_DIR=backend/app/data/generated_images

# Offline-development toggle. When `1`, the visual generator skips the
# fal.ai network call and serves a category-matching image from the
# local cache instead. Useful for working on UI without re-billing
# fal.ai or waiting on the network. Leave `0` in production.
MOODBOARD_DEMO_FALLBACK=0

# SketchUp realistic-furniture toggle (read by the Ruby plugin at
# SketchUp launch). When `true` (default), high-level zone builders
# emit detailed multi-piece geometry (desks paired with chairs, phone
# booths with glazed doors and stools, plants with terracotta pots).
# When `false`, every builder falls back to single-extruded volumes —
# full rollback for reversibility. See docs/CONFIGURATION.md.
DESIGN_OFFICE_REALISTIC_FURNITURE=true
