# Copy this file to .env and fill in the values. NEVER commit .env.
# Generate a fresh key at https://console.anthropic.com/settings/keys

ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL=claude-opus-4-7

# Local dev
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=5173

# MCPs (optional overrides — leave blank to use bundled vendor/ clients)
SKETCHUP_MCP_HOST=127.0.0.1
SKETCHUP_MCP_PORT=9876
AUTOCAD_MCP_HOST=127.0.0.1
AUTOCAD_MCP_PORT=9877
# When AutoCAD is running with mcp_dispatch.lsp loaded, point this at the
# watch folder the LISP monitors (usually `<repo>/autocad_watch`).
# AUTOCAD_MCP_WATCH_DIR=C:\Users\redaz\Desktop\Design Office\autocad_watch

# Token budget guardrails (section 16)
NIGHTLY_INPUT_TOKENS_BUDGET=300000
NIGHTLY_OUTPUT_TOKENS_BUDGET=100000

# fal.ai (NanoBanana Pro). Generate a key at https://fal.ai/dashboard/keys
# Used for the visual moodboard + 2D zone-overlay surfaces.
FAL_KEY=REPLACE_ME
NANOBANANA_CACHE_DIR=backend/app/data/generated_images

# iter-30B demo mode — when `1`, the NanoBanana client never reaches
# fal.ai. On cache miss it serves a deterministic image from the
# existing cache pool (~123 PNGs in NANOBANANA_CACHE_DIR, classified
# by 3:2 / 4:3). Use this when fal.ai credits are exhausted or for
# offline demos. The picked image is written to the prompt's
# cache_path so subsequent identical requests are real cache hits.
# Set to `0` (or remove) to re-enable real generation.
MOODBOARD_DEMO_FALLBACK=0

# iter-29 — SketchUp realistic furniture toggle (read by the Ruby
# plugin at SketchUp launch). When `true` (default), high-level zone
# builders emit detailed multi-piece geometry (desks paired with
# chairs, phone booths with glazed doors and stools, plants with
# terracotta pots, etc.). When `false`, every builder falls back to
# the legacy single-extruded-volume rendering used pre-iter-29 — full
# rollback for reversibility. See docs/CONFIGURATION.md.
DESIGN_OFFICE_REALISTIC_FURNITURE=true
