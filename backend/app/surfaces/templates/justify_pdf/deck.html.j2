<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ client_name }} — {{ variant_title }}</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{# `display=block` so Chromium waits for the webfonts before painting.
   Combined with `--virtual-time-budget=25000` on the Chrome side this
   gives every weight + variation axis time to land before print. #}
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,200..900,0..100;1,9..144,200..900,0..100&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=block">

{# Force-load the weights + axes we use, so Chromium doesn't decide they
   are optional and skip them. The hidden 1×1 nodes tickle the loader. #}
<div style="position:absolute;left:-9999px;top:-9999px;visibility:hidden;font-family:'JetBrains Mono',monospace;">
  ABCDEFGHIJKLMNOPQRSTUVWXYZ abcdefghijklmnopqrstuvwxyz 0123456789
</div>
<div style="position:absolute;left:-9999px;top:-9999px;visibility:hidden;font-family:'Inter',sans-serif;font-weight:300;">.</div>
<div style="position:absolute;left:-9999px;top:-9999px;visibility:hidden;font-family:'Inter',sans-serif;font-weight:500;">.</div>
<div style="position:absolute;left:-9999px;top:-9999px;visibility:hidden;font-family:'Fraunces',serif;font-weight:700;">.</div>
<div style="position:absolute;left:-9999px;top:-9999px;visibility:hidden;font-family:'Fraunces',serif;font-style:italic;font-weight:400;">.</div>

<style>
  /* ============================================================== */
  /* Iter-33 follow-up — magazine-grade PDF deck.                     */
  /* HTML is fed to headless Chromium                                 */
  /* (`chrome --headless --print-to-pdf`) at landscape 16:9 / 1920×1080.*/
  /* @page sets exact 13.333 in × 7.5 in, each .slide is a forced     */
  /* page break.                                                      */
  /* ============================================================== */

  @page {
    size: 13.333in 7.5in;
    margin: 0;
  }

  :root {
    /* Organic Modern palette — sourced from frontend/tailwind.config.ts */
    --canvas: #FAF7F2;
    --canvas-alt: #F4EFE6;
    --bone: #FFFCF6;
    --ink: #1C1F1A;
    --ink-soft: #2F3330;
    --ink-muted: #7F837D;
    --forest: #2F4A3F;
    --forest-deep: #1F3329;
    --sand: #C9B79C;
    --sand-deep: #A0886A;
    --sun: #E8C547;
    --terracotta: #A0522D;
    --mist-100: #ECE9E0;
    --mist-200: #DCD7CA;
    --mist-300: #C6C1B4;
    --hairline: rgba(28, 31, 26, 0.10);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--canvas);
    color: var(--ink);
    font-family: "Inter", system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.5;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  .slide {
    width: 13.333in;
    height: 7.5in;
    page-break-after: always;
    page-break-inside: avoid;
    background: var(--canvas);
    position: relative;
    overflow: hidden;
    padding: 0.7in 0.8in;
  }
  .slide:last-child { page-break-after: auto; }
  .slide.full-bleed { padding: 0; }

  /* ---------- editorial primitives ---------- */
  .eyebrow {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--forest);
  }
  .kicker {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
  }
  .h1 {
    font-family: "Fraunces", "Times New Roman", serif;
    font-variation-settings: "opsz" 144, "wght" 600, "SOFT" 0;
    font-size: 64px;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-top: 6px;
  }
  .h1-italic {
    font-family: "Fraunces", "Times New Roman", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 30;
    font-size: 60px;
    line-height: 1.05;
    letter-spacing: -0.018em;
    color: var(--ink);
  }
  .lede {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 36, "wght" 350, "SOFT" 20;
    font-size: 22px;
    line-height: 1.4;
    color: var(--ink-soft);
    margin-top: 0.18in;
    max-width: 7.5in;
  }
  .body {
    font-family: "Inter", sans-serif;
    color: var(--ink-soft);
    font-size: 14px;
    line-height: 1.6;
  }
  .body-large {
    font-family: "Inter", sans-serif;
    color: var(--ink-soft);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 400;
  }
  .mono {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--ink-muted);
    letter-spacing: 0.08em;
  }

  .rule {
    height: 1px;
    background: var(--sand);
    width: 4in;
    margin: 0.18in 0;
  }
  .rule-tiny { width: 1.5in; }

  .folio {
    position: absolute;
    bottom: 0.35in;
    right: 0.5in;
    font-family: "JetBrains Mono", monospace;
    font-size: 8px;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
  }
  .folio-light {
    color: rgba(255,255,255,0.7);
  }
  .corner-mark {
    position: absolute;
    top: 0.4in;
    right: 0.5in;
    font-family: "JetBrains Mono", monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
  }
  .corner-mark-light { color: rgba(255,255,255,0.7); }

  /* ============================================================== */
  /* SLIDE I — COVER (full-bleed atmosphere)                         */
  /* ============================================================== */

  .cover {
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .cover .bg {
    position: absolute; inset: 0;
    background: var(--mist-200);
  }
  .cover .bg img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .cover .scrim {
    position: absolute; inset: 0;
    background: linear-gradient(
      90deg,
      rgba(28,31,26,0.78) 0%,
      rgba(28,31,26,0.55) 38%,
      rgba(28,31,26,0.18) 65%,
      rgba(28,31,26,0.0) 100%
    );
  }
  .cover .grain {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 20% 80%, rgba(232, 197, 71, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(160, 82, 45, 0.05) 0%, transparent 50%);
  }
  .cover .text {
    position: relative;
    z-index: 2;
    height: 100%;
    padding: 0.9in 0.8in;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: white;
  }
  .cover .eyebrow-light {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(232, 197, 71, 0.9);
  }
  .cover-title {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 50;
    font-size: 138px;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: white;
    margin-top: 0.2in;
  }
  .cover-subtitle {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "wght" 500, "SOFT" 0;
    font-size: 38px;
    line-height: 1.1;
    color: rgba(255,255,255,0.92);
    margin-top: 0.25in;
  }
  .cover-meta {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 0.6in;
    padding-top: 0.3in;
    border-top: 1px solid rgba(255,255,255,0.18);
    max-width: 9in;
  }
  .cover-meta .item .kicker {
    color: rgba(255,255,255,0.55);
    display: block; margin-bottom: 6px;
  }
  .cover-meta .item .v {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 500;
    font-size: 26px;
    color: white; line-height: 1;
  }
  .cover-footer {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.16em;
    color: rgba(255,255,255,0.5);
  }

  /* ============================================================== */
  /* SLIDE II — VISION pull quote                                    */
  /* ============================================================== */

  .pq {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    height: 100%;
    padding: 0.5in 1.5in;
  }
  .pq-mark {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 700;
    font-size: 220px;
    color: var(--sand);
    line-height: 0.5;
    margin-bottom: -0.15in;
  }
  .pq-text {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 350, "SOFT" 50;
    font-size: 56px;
    line-height: 1.15;
    letter-spacing: -0.015em;
    color: var(--ink);
    max-width: 9in;
  }
  .pq-attr {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--forest);
    letter-spacing: 0.22em;
    margin-top: 0.3in;
    text-transform: uppercase;
  }
  .pq-rule {
    width: 1.5in;
    height: 1px;
    background: var(--sand);
    margin: 0.25in 0 0 0;
  }

  /* ============================================================== */
  /* SLIDE III — ABOUT (bento)                                       */
  /* ============================================================== */

  .bento {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    grid-template-rows: 1.4fr 1fr 1fr;
    gap: 0.18in;
    margin-top: 0.4in;
    height: 4.6in;
  }
  .bento-card {
    background: var(--bone);
    border: 1px solid var(--mist-200);
    padding: 0.3in 0.32in;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
  }
  .bento-card.feature {
    grid-column: span 1;
    grid-row: span 2;
    background: var(--forest);
    color: white;
    border-color: var(--forest);
  }
  .bento-card.feature .kicker { color: rgba(232,197,71,0.9); }
  .bento-card.feature .bento-value {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 50;
    font-size: 64px;
    line-height: 0.95;
    color: white;
    margin-top: auto;
  }
  .bento-card.feature .bento-detail { color: rgba(255,255,255,0.75); margin-top: 12px; }
  .bento-card .bento-value {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "wght" 500, "SOFT" 0;
    font-size: 38px;
    line-height: 1;
    color: var(--ink);
    margin-top: 8px;
  }
  .bento-card .bento-value-italic {
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 30;
  }
  .bento-card .bento-detail {
    font-family: "Inter", sans-serif;
    font-size: 12px;
    color: var(--ink-muted);
    line-height: 1.5;
    margin-top: 8px;
  }
  .bento-card.tall { grid-row: span 2; }
  .bento-card.image { padding: 0; }
  .bento-card.image img { width: 100%; height: 100%; object-fit: cover; }

  /* ============================================================== */
  /* SLIDE IV — BRIEF (narrative + sidebar image)                    */
  /* ============================================================== */

  .brief-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0.45in;
    margin-top: 0.35in;
    height: 4.7in;
  }
  .brief-text {
    columns: 1;
    font-size: 14.5px;
    line-height: 1.62;
    color: var(--ink-soft);
  }
  .brief-text p { margin-bottom: 0.18in; break-inside: avoid; }
  .brief-text p:first-child::first-line { font-weight: 500; color: var(--ink); }
  .brief-image {
    background: var(--mist-100);
    overflow: hidden;
    position: relative;
  }
  .brief-image img { width: 100%; height: 100%; object-fit: cover; }
  .brief-image .tile-label {
    position: absolute;
    bottom: 14px; left: 14px;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: white;
    background: rgba(28,31,26,0.55);
    padding: 6px 12px;
    text-transform: uppercase;
  }

  /* ============================================================== */
  /* SLIDE V — PROGRAMME (6-card grid)                               */
  /* ============================================================== */

  .prog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.18in;
    margin-top: 0.45in;
  }
  .prog-card {
    background: var(--bone);
    border: 1px solid var(--mist-200);
    padding: 0.28in 0.3in;
    min-height: 1.7in;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .prog-card .kicker { color: var(--forest); }
  .prog-card .body { font-size: 13px; margin-top: 8px; }
  .prog-card .num {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 30;
    font-size: 38px;
    color: var(--sand-deep);
    line-height: 1;
    margin-top: auto;
    padding-top: 12px;
  }

  /* ============================================================== */
  /* SLIDE VI — THREE MACRO ZONINGS · OVERVIEW                        */
  /* ============================================================== */

  .three-overview {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 0.5in;
    margin-top: 0.45in;
    height: 4.6in;
  }
  .three-overview-text { padding-top: 0.1in; }
  .three-overview-text .body-large { margin-top: 0.25in; }
  .three-strip {
    display: grid;
    grid-template-rows: repeat(3, 1fr);
    gap: 0.14in;
  }
  .three-strip-row {
    background: var(--bone);
    border: 1px solid var(--mist-200);
    padding: 0.2in 0.25in;
    display: grid;
    grid-template-columns: 0.5in 1fr auto;
    align-items: center;
    gap: 0.22in;
  }
  .three-strip-row.retained { border-color: var(--forest); border-width: 1.5px; background: rgba(47, 74, 63, 0.04); }
  .three-strip-row .num {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 30;
    font-size: 32px;
    color: var(--sand-deep);
    line-height: 1;
  }
  .three-strip-row.retained .num { color: var(--forest); }
  .three-strip-row .name {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 500;
    font-size: 18px;
    color: var(--ink);
  }
  .three-strip-row.retained .name { font-variation-settings: "opsz" 36, "wght" 700; }
  .three-strip-row .one-liner {
    font-family: "Inter", sans-serif;
    font-size: 11.5px;
    color: var(--ink-muted);
    margin-top: 2px;
  }
  .three-strip-row .badge {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--ink-muted);
  }
  .three-strip-row.retained .badge { color: var(--forest); }

  /* ============================================================== */
  /* SLIDES VII / VIII / IX — variants (full-bleed)                  */
  /* ============================================================== */

  .variant-bleed {
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  .variant-bleed .bg {
    position: absolute; inset: 0;
    background: var(--mist-200);
  }
  .variant-bleed .bg img {
    width: 100%; height: 100%; object-fit: cover;
  }
  .variant-bleed .scrim {
    position: absolute; inset: 0;
    background: linear-gradient(
      180deg,
      rgba(28,31,26,0.0) 0%,
      rgba(28,31,26,0.05) 50%,
      rgba(28,31,26,0.55) 80%,
      rgba(28,31,26,0.85) 100%
    );
  }
  .variant-bleed .text {
    position: relative;
    z-index: 2;
    height: 100%;
    padding: 0.7in 0.9in;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: white;
  }
  .variant-bleed .top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .variant-bleed .badge-pill {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    letter-spacing: 0.22em;
    background: rgba(255,255,255,0.18);
    color: white;
    padding: 8px 16px;
    text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.3);
  }
  .variant-bleed .badge-pill.retained {
    background: var(--forest);
    border-color: var(--forest);
    color: white;
  }
  .variant-bleed .v-num {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    color: rgba(232, 197, 71, 0.9);
  }
  .variant-bleed .v-title {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 144, "wght" 400, "SOFT" 40;
    font-size: 96px;
    line-height: 0.98;
    letter-spacing: -0.02em;
    color: white;
    margin: 0;
  }
  .variant-bleed .v-subtitle {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 400;
    font-size: 22px;
    color: rgba(255,255,255,0.78);
    margin-top: 0.18in;
    max-width: 7in;
    line-height: 1.4;
  }
  .variant-bleed .v-stats {
    display: flex; gap: 0.5in;
    padding-top: 0.25in;
    border-top: 1px solid rgba(255,255,255,0.2);
    max-width: 7in;
  }
  .variant-bleed .v-stats .item .kicker {
    color: rgba(255,255,255,0.55); display: block; margin-bottom: 4px;
  }
  .variant-bleed .v-stats .item .val {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 500;
    font-size: 22px;
    color: white; line-height: 1;
  }

  /* ============================================================== */
  /* SLIDE X — WHY WE CHOSE — comparison chart                       */
  /* ============================================================== */

  .compare {
    margin-top: 0.45in;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.18in;
  }
  .compare-row {
    display: grid;
    grid-template-columns: 1.4in 1fr;
    align-items: center;
    gap: 0.3in;
    padding: 0.18in 0;
    border-bottom: 1px solid var(--hairline);
  }
  .compare-row:last-child { border-bottom: none; }
  .compare-row .criterion {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 500;
    font-size: 16px;
    color: var(--ink);
  }
  .compare-bars {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0.3in;
  }
  .compare-bar {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .compare-bar .label-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .compare-bar .v-name {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }
  .compare-bar .v-name.retained { color: var(--forest); font-weight: 500; }
  .compare-bar .v-score {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    color: var(--ink);
  }
  .compare-bar .track {
    height: 6px;
    background: var(--mist-100);
    position: relative;
    border-radius: 3px;
  }
  .compare-bar .fill {
    height: 100%;
    background: var(--sand-deep);
    border-radius: 3px;
  }
  .compare-bar.retained .fill { background: var(--forest); }
  .compare-legend {
    display: flex; gap: 0.5in;
    margin-top: 0.4in;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.18em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }
  .compare-legend .dot {
    display: inline-block;
    width: 8px; height: 8px; border-radius: 50%;
    margin-right: 6px;
    vertical-align: middle;
  }
  .compare-legend .dot.retained { background: var(--forest); }
  .compare-legend .dot.explored { background: var(--sand-deep); }

  /* ============================================================== */
  /* SLIDE XI — RETAINED · FOCUS                                     */
  /* ============================================================== */

  .retained-focus {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 0.45in;
    margin-top: 0.4in;
    height: 4.7in;
  }
  .retained-image {
    background: var(--mist-100);
    overflow: hidden;
    position: relative;
  }
  .retained-image img { width: 100%; height: 100%; object-fit: cover; }
  .retained-stack {
    display: flex;
    flex-direction: column;
    gap: 0.18in;
  }
  .retained-stack .stat {
    background: var(--bone);
    border: 1px solid var(--mist-200);
    padding: 0.22in 0.28in;
  }
  .retained-stack .stat.feature {
    background: var(--forest);
    color: white;
    border-color: var(--forest);
  }
  .retained-stack .stat.feature .kicker { color: rgba(232, 197, 71, 0.9); }
  .retained-stack .stat .val {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "wght" 600, "SOFT" 0;
    font-size: 36px;
    line-height: 1;
    margin-top: 6px;
  }
  .retained-stack .stat.feature .val { color: white; }

  /* ============================================================== */
  /* SLIDE XII — ATMOSPHERE                                          */
  /* ============================================================== */

  .atm {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25in;
    margin-top: 0.35in;
    height: 4in;
  }
  .atm-tile {
    background: var(--mist-100);
    overflow: hidden;
    position: relative;
  }
  .atm-tile img { width: 100%; height: 100%; object-fit: cover; }
  .atm-tile .tile-label {
    position: absolute;
    bottom: 14px; left: 14px;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: white;
    background: rgba(28,31,26,0.55);
    padding: 6px 12px;
    text-transform: uppercase;
  }
  .palette-strip {
    display: flex; gap: 2px;
    margin-top: 0.22in;
    height: 0.45in;
  }
  .palette-chip {
    flex: 1;
    display: flex;
    align-items: flex-end;
    padding: 6px 8px;
    color: rgba(255,255,255,0.85);
    font-family: "JetBrains Mono", monospace;
    font-size: 8px;
    letter-spacing: 0.15em;
  }
  .palette-chip.dark-text { color: rgba(28,31,26,0.55); }
  .atmosphere-quote {
    font-family: "Fraunces", serif;
    font-style: italic;
    font-variation-settings: "opsz" 36, "wght" 350, "SOFT" 30;
    font-size: 18px;
    color: var(--ink);
    margin-top: 0.25in;
    text-align: center;
  }

  /* ============================================================== */
  /* SLIDES XIII / XIV — MATERIALS / FURNITURE (image left + list)    */
  /* ============================================================== */

  .matfur {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 0.45in;
    margin-top: 0.4in;
    height: 4.7in;
  }
  .matfur-image {
    background: var(--mist-100);
    overflow: hidden;
    border: 1px solid var(--mist-200);
    position: relative;
  }
  .matfur-image img { width: 100%; height: 100%; object-fit: cover; }
  .matfur-image .tile-label {
    position: absolute;
    bottom: 14px; left: 14px;
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: white;
    background: rgba(28,31,26,0.55);
    padding: 6px 12px;
    text-transform: uppercase;
  }
  .matfur-list {
    display: flex; flex-direction: column; gap: 0.05in;
  }
  .matfur-list li {
    list-style: none;
    padding: 0.18in 0.05in;
    border-bottom: 1px solid var(--hairline);
    display: grid;
    grid-template-columns: 0.4in 1fr;
    gap: 0.15in;
    align-items: baseline;
  }
  .matfur-list li:last-child { border-bottom: none; }
  .matfur-list li .num {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    color: var(--ink-muted);
    letter-spacing: 0.18em;
  }
  .matfur-list li .it-primary {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 500;
    font-size: 16px;
    color: var(--ink);
    line-height: 1.2;
  }
  .matfur-list li .it-secondary {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--ink-muted);
    letter-spacing: 0.08em;
    margin-top: 4px;
    text-transform: uppercase;
  }

  /* ============================================================== */
  /* SLIDE XV — PULL QUOTE (Nieuwenhuis)                             */
  /* ============================================================== */
  /* uses .pq from slide II                                          */

  /* ============================================================== */
  /* SLIDE XVI — EVIDENCE 3×2                                         */
  /* ============================================================== */

  .ev-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 1fr 1fr;
    gap: 0.18in;
    margin-top: 0.45in;
    height: 4.6in;
  }
  .ev-card {
    background: var(--bone);
    border: 1px solid var(--mist-200);
    padding: 0.3in 0.32in;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .ev-card .kicker { color: var(--forest); }
  .ev-card .takeaway {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-top: 12px;
  }
  .ev-card .citation {
    font-family: "JetBrains Mono", monospace;
    font-style: italic;
    font-size: 9px;
    letter-spacing: 0.08em;
    color: var(--ink-muted);
    margin-top: auto;
    padding-top: 14px;
  }

  /* ============================================================== */
  /* SLIDE XVII — KPI DIALS (CSS conic-gradient rings)               */
  /* ============================================================== */

  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.3in;
    margin-top: 0.5in;
  }
  .kpi-tile {
    background: var(--bone);
    border: 1px solid var(--mist-200);
    padding: 0.32in 0.25in;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .ring {
    width: 2.2in;
    height: 2.2in;
    border-radius: 50%;
    background:
      conic-gradient(from 0deg, var(--forest) 0% var(--p), var(--mist-200) var(--p) 100%);
    display: grid;
    place-items: center;
    margin-bottom: 0.18in;
  }
  .ring::before {
    content: "";
    width: 1.65in;
    height: 1.65in;
    background: var(--bone);
    border-radius: 50%;
    grid-area: 1 / 1;
  }
  .ring .ring-text {
    grid-area: 1 / 1;
    text-align: center;
    z-index: 1;
  }
  .ring .ring-num {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 144, "wght" 600, "SOFT" 0;
    font-size: 32px;
    color: var(--ink);
    line-height: 1;
  }
  .ring .ring-unit {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    margin-top: 4px;
  }
  .kpi-tile .label {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    color: var(--forest);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .kpi-tile .desc {
    font-family: "Inter", sans-serif;
    font-size: 11px;
    color: var(--ink-muted);
    margin-top: 8px;
    line-height: 1.4;
  }

  /* ============================================================== */
  /* SLIDE XVIII — NEXT STEPS (vertical timeline)                    */
  /* ============================================================== */

  /* Timeline — tightened in iter-33 follow-up : 8 rows must clear
     a 7.5in slide with header + h1 + rule consuming the top ~2.4in.
     0.13in vertical padding × 8 rows = 2.08in for rows ; centerline
     dot is positioned at top: 0.22in to track the row's baseline. */
  .timeline {
    margin-top: 0.35in;
    position: relative;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 0.95in;
    top: 0.13in;
    bottom: 0.13in;
    width: 1px;
    background: var(--sand);
  }
  .timeline-row {
    display: grid;
    grid-template-columns: 1.3in 1fr 1.5in;
    gap: 0.3in;
    align-items: baseline;
    padding: 0.13in 0;
    position: relative;
  }
  .timeline-row::before {
    content: "";
    position: absolute;
    left: 0.93in;
    top: 0.22in;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--bone);
    border: 1.5px solid var(--forest);
  }
  .timeline-row.feature::before {
    background: var(--forest);
    width: 12px; height: 12px;
    left: 0.92in;
  }
  .timeline-row .when {
    font-family: "JetBrains Mono", monospace;
    font-size: 10px;
    color: var(--forest);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .timeline-row .what {
    font-family: "Fraunces", serif;
    font-variation-settings: "opsz" 36, "wght" 500;
    font-size: 16px;
    color: var(--ink);
    padding-left: 0.45in;
    line-height: 1.3;
  }
  .timeline-row .who {
    font-family: "JetBrains Mono", monospace;
    font-size: 9px;
    color: var(--ink-muted);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-align: right;
  }
</style>
</head>
<body>

{# ─────────────────────── I — COVER ─────────────────────── #}
<section class="slide cover">
  <div class="bg">
    {% if cover_image %}
      <img src="{{ cover_image }}" alt="">
    {% endif %}
  </div>
  <div class="scrim"></div>
  <div class="grain"></div>
  <div class="text">
    <div>
      <div class="eyebrow-light">Design Office · Client Argumentaire</div>
      <h1 class="cover-title">{{ client_name }}</h1>
      <div class="cover-subtitle">« {{ variant_title }} »</div>
    </div>

    <div>
      <div class="cover-meta">
        <div class="item">
          <span class="kicker">Parti</span>
          <div class="v">{{ parti_label }}</div>
        </div>
        <div class="item">
          <span class="kicker">Desks</span>
          <div class="v">{{ workstation_count }}</div>
        </div>
        <div class="item">
          <span class="kicker">Total programmed</span>
          <div class="v">{{ total_m2 }} m²</div>
        </div>
      </div>
      <div class="cover-footer" style="margin-top: 0.5in;">
        {{ today }} &nbsp;·&nbsp; Built with Opus 4.7 &nbsp;·&nbsp; MIT License
      </div>
    </div>
  </div>
</section>

{# ─────────────────────── II — VISION pull quote ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">II — VISION</span>
  <div class="pq">
    <span class="pq-mark">&ldquo;</span>
    <p class="pq-text">{{ vision_quote }}</p>
    <div class="pq-rule"></div>
    <span class="pq-attr">{{ client_name }} · {{ variant_title }}</span>
  </div>
  <span class="folio">II</span>
</section>

{# ─────────────────────── III — ABOUT bento ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">III — ABOUT THE PROJECT</span>
  <span class="eyebrow">About the project</span>
  <h2 class="h1-italic">A studio for {{ client_name }}.</h2>
  <div class="rule"></div>
  <div class="bento">
    <div class="bento-card feature">
      <div>
        <span class="kicker">Client</span>
      </div>
      <div>
        <div class="bento-value">{{ client_name }}</div>
        <p class="bento-detail">{{ about_summary }}</p>
      </div>
    </div>
    {% for cell in about_cells %}
    <div class="bento-card{% if cell.tall %} tall{% endif %}">
      <span class="kicker">{{ cell.label }}</span>
      <div class="bento-value{% if cell.italic %} bento-value-italic{% endif %}">{{ cell.value }}</div>
      {% if cell.detail %}
      <p class="bento-detail">{{ cell.detail }}</p>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  <span class="folio">III</span>
</section>

{# ─────────────────────── IV — BRIEF ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">IV — THE BRIEF</span>
  <span class="eyebrow">The brief</span>
  <h2 class="h1-italic">What we heard.</h2>
  <div class="rule"></div>
  <div class="brief-grid">
    <div class="brief-text">
      <p class="lede" style="margin-top:0;">{{ brief_lede }}</p>
      {% for paragraph in brief_paragraphs %}
      <p>{{ paragraph }}</p>
      {% endfor %}
    </div>
    <div class="brief-image">
      {% if brief_image %}
        <img src="{{ brief_image }}" alt="">
        <span class="tile-label">Biophilic mood</span>
      {% endif %}
    </div>
  </div>
  <span class="folio">IV</span>
</section>

{# ─────────────────────── V — PROGRAMME ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">V — PROGRAMME</span>
  <span class="eyebrow">Programme</span>
  <h2 class="h1-italic">What we sized.</h2>
  <div class="rule"></div>
  <div class="prog-grid">
    {% for item in programme_items %}
    <div class="prog-card">
      <div>
        <span class="kicker">{{ item.label }}</span>
        <p class="body">{{ item.detail }}</p>
      </div>
      <div class="num">{{ item.value }}</div>
    </div>
    {% endfor %}
  </div>
  <span class="folio">V</span>
</section>

{# ─────────────────────── VI — THREE MACRO-ZONINGS · OVERVIEW ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">VI — THE THREE HYPOTHESES</span>
  <span class="eyebrow">The three macro-zonings</span>
  <h2 class="h1-italic">Three hypotheses, one bet.</h2>
  <div class="rule"></div>
  <div class="three-overview">
    <div class="three-overview-text">
      <p class="body-large">
        Three layouts were composed and reviewed for {{ client_name }}.
        Each takes a different bet on where the day's energy lands —
        north for focus, south for ritual, distributed for flexibility.
        The retained variant is the one whose trade-offs best fit the
        culture and the building.
      </p>
    </div>
    <div class="three-strip">
      {% for v in variants_overview %}
      <div class="three-strip-row{% if v.retained %} retained{% endif %}">
        <span class="num">{{ v.numeral }}</span>
        <div>
          <div class="name">{{ v.title }}</div>
          <div class="one-liner">{{ v.one_liner }}</div>
        </div>
        <span class="badge">{{ "RETAINED" if v.retained else "EXPLORED" }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  <span class="folio">VI</span>
</section>

{# ─────────────────────── VII / VIII / IX — VARIANT FULL-BLEEDS ─────────────────────── #}
{% for v in variant_pages %}
<section class="slide variant-bleed">
  <div class="bg">
    {% if v.image %}
      <img src="{{ v.image }}" alt="">
    {% endif %}
  </div>
  <div class="scrim"></div>
  <div class="text">
    <div class="top-row">
      <span class="v-num">{{ v.numeral }} — VARIANT {{ loop.index }}</span>
      <span class="badge-pill{% if v.retained %} retained{% endif %}">
        {{ "RETAINED" if v.retained else "EXPLORED" }}
      </span>
    </div>
    <div>
      <h2 class="v-title">{{ v.title }}</h2>
      <p class="v-subtitle">{{ v.subtitle }}</p>
      <div class="v-stats">
        <div class="item">
          <span class="kicker">Desks</span>
          <span class="val">{{ v.desks }}</span>
        </div>
        <div class="item">
          <span class="kicker">Flex ratio</span>
          <span class="val">{{ "%.2f"|format(v.flex) }}</span>
        </div>
        <div class="item">
          <span class="kicker">Total m²</span>
          <span class="val">{{ v.total }}</span>
        </div>
      </div>
    </div>
  </div>
  <span class="corner-mark corner-mark-light">{{ v.numeral }} — {{ v.title|upper }}</span>
  <span class="folio folio-light">{{ v.numeral }}</span>
</section>
{% endfor %}

{# ─────────────────────── X — WHY WE CHOSE ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">X — THE DECISION</span>
  <span class="eyebrow">Why we chose</span>
  <h2 class="h1-italic">Why {{ retained_short_title }}.</h2>
  <div class="rule"></div>
  <div class="compare">
    {% for crit in compare_criteria %}
    <div class="compare-row">
      <div class="criterion">{{ crit.name }}</div>
      <div class="compare-bars">
        {% for bar in crit.bars %}
        <div class="compare-bar{% if bar.retained %} retained{% endif %}">
          <div class="label-row">
            <span class="v-name{% if bar.retained %} retained{% endif %}">{{ bar.short }}</span>
            <span class="v-score">{{ bar.score }}/5</span>
          </div>
          <div class="track">
            <div class="fill" style="width: {{ (bar.score / 5 * 100)|round(0, 'floor')|int }}%;"></div>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>
  <div class="compare-legend">
    <span><span class="dot retained"></span>Retained</span>
    <span><span class="dot explored"></span>Explored</span>
  </div>
  <span class="folio">X</span>
</section>

{# ─────────────────────── XI — RETAINED · FOCUS ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XI — THE RETAINED VARIANT</span>
  <span class="eyebrow">The retained variant</span>
  <h2 class="h1-italic">{{ variant_title }}.</h2>
  <div class="rule"></div>
  <div class="retained-focus">
    <div class="retained-image">
      {% if retained_image %}
        <img src="{{ retained_image }}" alt="">
      {% endif %}
    </div>
    <div class="retained-stack">
      <div class="stat feature">
        <span class="kicker">Parti</span>
        <div class="val">{{ parti_label }}</div>
      </div>
      <div class="stat">
        <span class="kicker">Desks</span>
        <div class="val">{{ workstation_count }}</div>
      </div>
      <div class="stat">
        <span class="kicker">Flex ratio</span>
        <div class="val">{{ "%.2f"|format(flex_ratio) }}</div>
      </div>
      <div class="stat">
        <span class="kicker">Total programmed</span>
        <div class="val">{{ total_m2 }} m²</div>
      </div>
    </div>
  </div>
  <span class="folio">XI</span>
</section>

{# ─────────────────────── XII — ATMOSPHERE ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XII — ATMOSPHERE</span>
  <span class="eyebrow">Atmosphere &amp; biophilia</span>
  <h2 class="h1-italic">How it feels.</h2>
  <div class="rule"></div>
  <div class="atm">
    <div class="atm-tile">
      {% if atmosphere_image %}
        <img src="{{ atmosphere_image }}" alt="">
        <span class="tile-label">Atmosphere</span>
      {% endif %}
    </div>
    <div class="atm-tile">
      {% if biophilic_image %}
        <img src="{{ biophilic_image }}" alt="">
        <span class="tile-label">Biophilic</span>
      {% endif %}
    </div>
  </div>
  {% if tagline %}
  <div class="atmosphere-quote">« {{ tagline }} »</div>
  {% endif %}
  {% if palette_hexes %}
  <div class="palette-strip">
    {% for hex in palette_hexes %}
    <div class="palette-chip{% if hex|lower in ['#faf7f2','#fffcf6','#e8c547','#c9b79c'] %} dark-text{% endif %}" style="background: {{ hex }};">{{ hex|upper }}</div>
    {% endfor %}
  </div>
  {% endif %}
  <span class="folio">XII</span>
</section>

{# ─────────────────────── XIII — MATERIALS ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XIII — MATERIALS</span>
  <span class="eyebrow">Materials</span>
  <h2 class="h1-italic">The palette, made real.</h2>
  <div class="rule"></div>
  <div class="matfur">
    <div class="matfur-image">
      {% if materials_image %}
        <img src="{{ materials_image }}" alt="">
        <span class="tile-label">Materials moodboard</span>
      {% endif %}
    </div>
    <ul class="matfur-list">
      {% for m in materials[:5] %}
      <li>
        <span class="num">{{ "%02d"|format(loop.index) }}</span>
        <div>
          <div class="it-primary">{{ m.primary }}</div>
          {% if m.secondary %}
          <div class="it-secondary">{{ m.secondary }}</div>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
  <span class="folio">XIII</span>
</section>

{# ─────────────────────── XIV — FURNITURE ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XIV — FURNITURE</span>
  <span class="eyebrow">Furniture</span>
  <h2 class="h1-italic">The pieces we picked.</h2>
  <div class="rule"></div>
  <div class="matfur">
    <div class="matfur-image">
      {% if furniture_image %}
        <img src="{{ furniture_image }}" alt="">
        <span class="tile-label">Furniture moodboard</span>
      {% endif %}
    </div>
    <ul class="matfur-list">
      {% for f in furniture[:5] %}
      <li>
        <span class="num">{{ "%02d"|format(loop.index) }}</span>
        <div>
          <div class="it-primary">{{ f.primary }}</div>
          {% if f.secondary %}
          <div class="it-secondary">{{ f.secondary }}</div>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
  <span class="folio">XIV</span>
</section>

{# ─────────────────────── XV — PULL QUOTE (Nieuwenhuis) ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XV — IN CONTEXT</span>
  <div class="pq">
    <span class="pq-mark">&ldquo;</span>
    <p class="pq-text">{{ pull_quote }}</p>
    <div class="pq-rule"></div>
    <span class="pq-attr">{{ pull_quote_attr }}</span>
  </div>
  <span class="folio">XV</span>
</section>

{# ─────────────────────── XVI — EVIDENCE ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XVI — EVIDENCE</span>
  <span class="eyebrow">Evidence · the studies behind the bet</span>
  <h2 class="h1-italic">What the literature says.</h2>
  <div class="rule"></div>
  <div class="ev-grid">
    {% for src in evidence %}
    <div class="ev-card">
      <span class="kicker">{{ src.kicker }}</span>
      <p class="takeaway">{{ src.takeaway }}</p>
      <div class="citation">{{ src.citation }}</div>
    </div>
    {% endfor %}
  </div>
  <span class="folio">XVI</span>
</section>

{# ─────────────────────── XVII — KPI DIALS ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XVII — EXPECTED RESULTS</span>
  <span class="eyebrow">Expected results · 6–12 months</span>
  <h2 class="h1-italic">What success looks like.</h2>
  <div class="rule"></div>
  <div class="kpi-grid">
    {% for k in kpi_dials %}
    <div class="kpi-tile">
      <span class="label">{{ k.label }}</span>
      <div class="ring" style="--p: {{ k.percent }}%;">
        <div class="ring-text">
          <div class="ring-num">{{ k.value }}</div>
          <div class="ring-unit">{{ k.unit }}</div>
        </div>
      </div>
      <div class="desc">{{ k.desc }}</div>
    </div>
    {% endfor %}
  </div>
  <span class="folio">XVII</span>
</section>

{# ─────────────────────── XVIII — NEXT STEPS TIMELINE ─────────────────────── #}
<section class="slide">
  <span class="corner-mark">XVIII — WHAT'S NEXT</span>
  <span class="eyebrow">Next steps</span>
  <h2 class="h1-italic">What it takes to start.</h2>
  <div class="rule"></div>
  <div class="timeline">
    {% for m in milestones %}
    <div class="timeline-row{% if m.feature %} feature{% endif %}">
      <span class="when">{{ m.when }}</span>
      <span class="what">{{ m.what }}</span>
      <span class="who">{{ m.who }}</span>
    </div>
    {% endfor %}
  </div>
  <span class="folio">XVIII</span>
</section>

</body>
</html>
