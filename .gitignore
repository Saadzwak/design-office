# --- Secrets & env ---
.env
.env.*
!.env.example
*.pem
*.key

# --- Python / backend ---
backend/.venv/
backend/venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/.pytest_cache/
backend/.ruff_cache/
backend/logs/
backend/dist/
backend/build/
backend/*.egg-info/

# --- Node / frontend ---
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/
frontend/tsconfig.tsbuildinfo
frontend/**/*.tsbuildinfo

# --- Vendor MCP internal git (we strip .git after clone but guard anyway) ---
vendor/**/.git
vendor/**/.venv

# --- Editor / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
.claude/

# --- Build artefacts ---
*.dwg.tmp
*.pdf.tmp
out/
tmp/

# --- NanoBanana cache ---
# The on-disk cache of fal.ai renders. One committed golden image
# lives in backend/tests/fixtures/lumen_visual_moodboard.png.
backend/app/data/generated_images/

# --- Mid-iteration debug screenshots (iter-32 / iter-33 review) ---
# These are full-bleed PNG renders we used during in-session visual
# review. They're not part of the product, just engineering scratch.
docs/screenshots/iter32_*/
docs/screenshots/iter33_*/

# --- Local backend run-time output ---
backend/app/out/
